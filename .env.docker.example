APP_NAME=VoltexaHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stderr
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=voltexahub
DB_USERNAME=voltexahub
DB_PASSWORD=secret

BROADCAST_CONNECTION=pusher
QUEUE_CONNECTION=database
CACHE_STORE=database

PUSHER_APP_ID=voltexahub-id
PUSHER_APP_KEY=voltexahub-key
PUSHER_APP_SECRET=voltexahub-secret
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@voltexahub.com
MAIL_FROM_NAME="VoltexaHub"

FILESYSTEM_DISK=public

FRONTEND_PATH=/var/www/voltexaforum
